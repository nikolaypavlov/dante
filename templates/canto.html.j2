<!doctype html>
<html lang="uk">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{{ title }} · Дантешопедія</title>
<link rel="stylesheet" href="{{ css_path }}" />
</head>
<body class="theme-{{ cantica_slug }}" data-current-file="{{ current_file }}">

<div class="chrome">
  <div class="chrome-left">
    <button class="nav-btn" onclick="togglePanel()" aria-label="Navigatio">&#9776;</button>
    <a class="project-mark" href="index.html">
      Arbor fontium<span class="sub">&middot; Dantis intertextus &middot;</span>
    </a>
  </div>
  <div class="theme-toggle">
    <a href="index.html"{% if cantica_slug == 'inferno' %} class="active"{% endif %}>Inferno</a>
    <a href="frontispicia_purgatorio.html"{% if cantica_slug == 'purgatorio' %} class="active"{% endif %}>Purgatorio</a>
    <a href="frontispicia_paradiso.html"{% if cantica_slug == 'paradiso' %} class="active"{% endif %}>Paradiso</a>
  </div>
</div>

<div class="side-panel-overlay" id="overlay" onclick="togglePanel()"></div>
<aside class="side-panel" id="sidePanel">
  <div class="side-panel-header">
    <h2>Navigatio</h2>
    <button class="side-panel-close" onclick="togglePanel()" aria-label="Закрити">&#x2715;</button>
  </div>
  <div id="panelContent"></div>
</aside>

<div class="folio" id="folio">
  <svg class="corner tl" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.2" style="color:var(--border-ink)">
      <path d="M6 6 L6 80 M6 6 L80 6"/>
      <path d="M14 14 Q 28 6, 42 20 Q 56 34, 48 48 Q 36 60, 20 52 Q 10 46, 14 30 Z"/>
      <path d="M20 20 Q 30 18, 36 28 Q 40 36, 32 40 Q 26 42, 22 34"/>
      <circle cx="42" cy="20" r="3" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.6"/>
      <circle cx="14" cy="30" r="2.5" fill="var(--gold)" stroke="none"/>
      <circle cx="48" cy="48" r="2.5" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.5"/>
      <path d="M50 14 Q 60 8, 72 14" stroke-width="0.8"/>
      <path d="M14 50 Q 8 60, 14 72" stroke-width="0.8"/>
      <path d="M56 6 Q 58 14, 66 14" />
      <path d="M6 56 Q 14 58, 14 66" />
    </g>
  </svg>
  <svg class="corner tr" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.2" style="color:var(--border-ink)">
      <path d="M6 6 L6 80 M6 6 L80 6"/>
      <path d="M14 14 Q 28 6, 42 20 Q 56 34, 48 48 Q 36 60, 20 52 Q 10 46, 14 30 Z"/>
      <circle cx="42" cy="20" r="3" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.6"/>
      <circle cx="14" cy="30" r="2.5" fill="var(--gold)" stroke="none"/>
      <circle cx="48" cy="48" r="2.5" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.5"/>
    </g>
  </svg>
  <svg class="corner bl" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.2" style="color:var(--border-ink)">
      <path d="M6 6 L6 80 M6 6 L80 6"/>
      <path d="M14 14 Q 28 6, 42 20 Q 56 34, 48 48 Q 36 60, 20 52 Q 10 46, 14 30 Z"/>
      <circle cx="42" cy="20" r="3" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.6"/>
      <circle cx="14" cy="30" r="2.5" fill="var(--gold)" stroke="none"/>
      <circle cx="48" cy="48" r="2.5" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.5"/>
    </g>
  </svg>
  <svg class="corner br" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.2" style="color:var(--border-ink)">
      <path d="M6 6 L6 80 M6 6 L80 6"/>
      <path d="M14 14 Q 28 6, 42 20 Q 56 34, 48 48 Q 36 60, 20 52 Q 10 46, 14 30 Z"/>
      <circle cx="42" cy="20" r="3" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.6"/>
      <circle cx="14" cy="30" r="2.5" fill="var(--gold)" stroke="none"/>
      <circle cx="48" cy="48" r="2.5" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.5"/>
    </g>
  </svg>

  <div class="folio-header">
    <div class="kicker" id="kicker">{{ kicker }}</div>
    <div class="cantica" id="cantica">{{ cantica }}</div>
    <div class="canto-row">
      <div class="canto-nav canto-nav-prev">{{ prev_link | safe }}</div>
      <div class="canto canto-current" id="canto">{{ title }}</div>
      <div class="canto-nav canto-nav-next">{{ next_link | safe }}</div>
    </div>
    <div class="subtitle-ua" id="subtitle">{{ subtitle_ua }}</div>
  </div>

  <div class="rule double"></div>

  <div class="folio-main">
    <div class="medallion-wrap">
      <div class="medallion" id="medallion">
        <svg class="tree-svg" id="tree"></svg>
        <div class="graph" id="graph"></div>
      </div>
    </div>
  </div>

  <footer class="colophon">
    <div class="rule double"></div>
    <div class="colophon-grid">
      <section class="col-argumentum">
        <h3>Argumentum</h3>
        <p id="summaryText">{{ summary_ua }}</p>
      </section>
      <section class="col-nota">
        <h3>Nota bene</h3>
        <p id="notaText"></p>
        <p class="cue">Наведіть курсор на картку або стрілку, щоб побачити латинську цитату, український переклад і характер зв'язку.</p>
      </section>
      <section class="col-legend">
        <h3>Typi relationis</h3>
        <div class="legend">
          <div class="legend-item"><span class="swatch ALLUSION"></span><span class="code">allusio</span><span class="lbl">пряма алюзія</span></div>
          <div class="legend-item"><span class="swatch STRUCTURE"></span><span class="code">structura</span><span class="lbl">структурне запозичення</span></div>
          <div class="legend-item"><span class="swatch THEMATIC"></span><span class="code">thematica</span><span class="lbl">тематична паралель</span></div>
          <div class="legend-item"><span class="swatch INVERSION"></span><span class="code">inversio</span><span class="lbl">навмисна інверсія</span></div>
          <div class="legend-item"><span class="swatch ONOMASTIC"></span><span class="code">nominis</span><span class="lbl">іменна референція</span></div>
          <div class="legend-item"><span class="swatch INDIRECT"></span><span class="code">per viam</span><span class="lbl">опосередковано через латинського посередника</span></div>
        </div>
      </section>
    </div>
    <div class="colophon-bar">
      <div><span style="font-style:italic">Dantis Alagherii</span> · Comedia</div>
      <div class="foliation" id="foliation">{{ foliation }}</div>
      <div id="versesInfo">{{ verses }}</div>
    </div>
  </footer>
</div>

<div class="tip" id="tip">
  <div class="tip-head" id="tipHead"></div>
  <div class="tip-sub" id="tipSub"></div>
  <div class="tip-type" id="tipType"></div>
  <div class="tip-quote" id="tipQuote"></div>
  <div class="tip-note" id="tipNote"></div>
  <div class="tip-lines" id="tipLines"></div>
</div>

<script>window.CANTO = {{ canto_json | safe }};</script>
<script src="{{ js_path }}"></script>
</body>
</html>
