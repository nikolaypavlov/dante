<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Дантешопедія -- Інтертекстуальний аналіз</title>
<link rel="stylesheet" href="{{ css_path }}">
<style>
body { max-width: 960px; margin: 0 auto; padding: 2rem 1rem; }
h1 { text-align: center; margin-bottom: 0.3rem; }
.subtitle { text-align: center; color: var(--text-muted); margin-bottom: 2rem; font-style: italic; }
.progress-bar { background: var(--col-light); border-radius: 4px; height: 18px; margin-bottom: 2rem; overflow: hidden; }
.progress-fill { height: 100%; background: #d4a853; border-radius: 4px; transition: width 0.3s; }
.progress-label { text-align: center; font-size: 0.85rem; color: var(--text-muted); margin-top: -1.6rem; position: relative; line-height: 18px; }
.cantica-section { margin-bottom: 2rem; }
.cantica-section h2 { border-bottom: 1px solid var(--col-light); padding-bottom: 0.3rem; margin-bottom: 0.8rem; }
.canto-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 6px; }
.canto-card { display: flex; align-items: center; justify-content: space-between; padding: 6px 10px; border-radius: 4px; font-size: 0.85rem; text-decoration: none; border: 1px solid var(--col-light); }
.canto-card.ready { color: var(--text); }
.canto-card.ready:hover { border-color: #d4a853; }
.canto-card.missing { color: var(--text-muted); opacity: 0.4; cursor: default; pointer-events: none; }
.badge { font-size: 0.7rem; background: var(--col-light); padding: 1px 5px; border-radius: 3px; color: var(--text-muted); }
.summary { text-align: center; color: var(--text-muted); font-size: 0.85rem; margin-top: 2rem; }
</style>
</head>
<body>

<h1>Дантешопедія</h1>
<p class="subtitle">Інтертекстуальний аналіз Божественної Комедії</p>

{% set total = cantos | length %}
{% set done = cantos | selectattr('html_exists') | list | length %}
{% set pct = (done / total * 100) | round | int %}
<div class="progress-bar"><div class="progress-fill" style="width:{{ pct }}%"></div></div>
<div class="progress-label">{{ done }}/{{ total }} канто ({{ pct }}%)</div>

{% for cantica_name, prefix, abbrev, count in cantica_list %}
<div class="cantica-section">
  <h2>{{ cantica_name }}</h2>
  <div class="canto-grid">
  {% for c in cantos if c.cantica == cantica_name %}
    {% if c.html_exists %}
    <a class="canto-card ready" href="{{ c.stem }}.html">{{ c.label }}{% if c.conn_count %}<span class="badge">{{ c.conn_count }}</span>{% endif %}</a>
    {% else %}
    <span class="canto-card missing">{{ c.label }}</span>
    {% endif %}
  {% endfor %}
  </div>
</div>
{% endfor %}

{% set total_conn = cantos | sum(attribute='conn_count') %}
<p class="summary">{{ done }} канто, {{ total_conn }} з'єднань</p>

</body>
</html>
