<!doctype html>
<html lang="uk">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Дантешопедія · Інтертекстуальний аналіз</title>
<link rel="stylesheet" href="{{ css_path }}" />
<style>
.index-progress { margin: 22px 0 30px; }
.index-progress .bar { position: relative; height: 10px; background: rgba(0,0,0,0.18); border: 1px solid var(--border-ink); border-radius: 2px; overflow: hidden; }
.index-progress .fill { position: absolute; inset: 0 auto 0 0; background: var(--gold); opacity: 0.75; }
.index-progress .label { text-align: center; margin-top: 8px; font-family: 'EB Garamond', serif; font-style: italic; color: var(--ink-dim); font-size: 13px; letter-spacing: 0.04em; }
.cantica-section { margin: 28px 0; }
.cantica-section h2 { font-family: 'UnifrakturMaguntia', serif; font-size: 28px; color: var(--gold); margin: 0 0 4px; text-align: center; letter-spacing: 0.03em; }
.cantica-section .lat { text-align: center; font-family: 'EB Garamond', serif; font-style: italic; color: var(--rubric); font-size: 13px; margin-bottom: 14px; letter-spacing: 0.06em; }
.canto-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(92px, 1fr)); gap: 8px; }
.canto-card { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 10px 6px; border: 1px solid var(--border-ink); background: rgba(0,0,0,0.12); border-radius: 2px; text-decoration: none; color: var(--ink); font-family: 'EB Garamond', serif; gap: 4px; transition: border-color 0.15s, background 0.15s; }
.canto-card .roman { font-family: 'UnifrakturMaguntia', serif; font-size: 20px; color: var(--gold); letter-spacing: 0.04em; line-height: 1; }
.canto-card .arabic { font-size: 11px; color: var(--ink-dim); font-style: italic; }
.canto-card .badge { display: inline-block; font-size: 10px; padding: 1px 6px; border: 1px solid var(--rubric); color: var(--rubric); border-radius: 8px; margin-top: 2px; letter-spacing: 0.04em; }
.canto-card:hover { border-color: var(--gold); background: rgba(0,0,0,0.24); }
.canto-card.missing { opacity: 0.22; pointer-events: none; }
.canto-card.missing .badge { border-color: var(--ink-dim); color: var(--ink-dim); }
.index-head { text-align: center; }
.index-head .mark { font-family: 'EB Garamond', serif; font-style: italic; color: var(--rubric); letter-spacing: 0.2em; font-size: 13px; }
.index-head h1 { font-family: 'UnifrakturMaguntia', serif; font-size: 56px; color: var(--gold); margin: 10px 0 4px; letter-spacing: 0.02em; }
.index-head .sub { font-family: 'EB Garamond', serif; font-style: italic; color: var(--ink-dim); font-size: 16px; }
</style>
</head>
<body class="theme-inferno">

<div class="chrome">
  <div class="chrome-left">
    <a class="project-mark" href="index.html">
      Arbor fontium<span class="sub">&middot; Dantis intertextus &middot;</span>
    </a>
  </div>
  <div class="theme-toggle">
    <a href="frontispicia_inferno.html">Inferno</a>
    <a href="frontispicia_purgatorio.html">Purgatorio</a>
    <a href="frontispicia_paradiso.html">Paradiso</a>
  </div>
</div>

<div class="folio" id="folio">
  <svg class="corner tl" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.2" style="color:var(--border-ink)">
      <path d="M6 6 L6 80 M6 6 L80 6"/>
      <path d="M14 14 Q 28 6, 42 20 Q 56 34, 48 48 Q 36 60, 20 52 Q 10 46, 14 30 Z"/>
      <circle cx="42" cy="20" r="3" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.6"/>
      <circle cx="14" cy="30" r="2.5" fill="var(--gold)" stroke="none"/>
    </g>
  </svg>
  <svg class="corner tr" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.2" style="color:var(--border-ink)">
      <path d="M6 6 L6 80 M6 6 L80 6"/>
      <path d="M14 14 Q 28 6, 42 20 Q 56 34, 48 48 Q 36 60, 20 52 Q 10 46, 14 30 Z"/>
      <circle cx="42" cy="20" r="3" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.6"/>
      <circle cx="14" cy="30" r="2.5" fill="var(--gold)" stroke="none"/>
    </g>
  </svg>
  <svg class="corner bl" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.2" style="color:var(--border-ink)">
      <path d="M6 6 L6 80 M6 6 L80 6"/>
      <path d="M14 14 Q 28 6, 42 20 Q 56 34, 48 48 Q 36 60, 20 52 Q 10 46, 14 30 Z"/>
      <circle cx="42" cy="20" r="3" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.6"/>
    </g>
  </svg>
  <svg class="corner br" viewBox="0 0 88 88" xmlns="http://www.w3.org/2000/svg">
    <g stroke="currentColor" fill="none" stroke-width="1.2" style="color:var(--border-ink)">
      <path d="M6 6 L6 80 M6 6 L80 6"/>
      <path d="M14 14 Q 28 6, 42 20 Q 56 34, 48 48 Q 36 60, 20 52 Q 10 46, 14 30 Z"/>
      <circle cx="42" cy="20" r="3" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.6"/>
    </g>
  </svg>

  <div class="index-head">
    <div class="mark">Arbor fontium · Dantis intertextus</div>
    <h1>Дантешопедія</h1>
    <div class="sub">Інтертекстуальний аналіз Божественної Комедії</div>
  </div>

  <div class="rule double"></div>

  <div class="index-progress">
    <div class="bar"><div class="fill" style="width: {{ pct }}%;"></div></div>
    <div class="label">{{ done }} / {{ total }} канто &middot; {{ pct }}%</div>
  </div>

  {% for cantica_name, prefix, abbrev, count in cantica_list %}
  <div class="cantica-section">
    <h2>{{ cantica_name }}</h2>
    <div class="lat">{{ cantica_lat[cantica_name] }}</div>
    <div class="canto-grid">
    {% for c in cantos if c.cantica == cantica_name %}
      {% if c.html_exists %}
      <a class="canto-card" href="{{ c.stem }}.html">
        <span class="roman">{{ c.roman }}</span>
        <span class="arabic">{{ c.num }}</span>
        {% if c.conn_count %}<span class="badge">{{ c.conn_count }}</span>{% endif %}
      </a>
      {% else %}
      <span class="canto-card missing">
        <span class="roman">{{ c.roman }}</span>
        <span class="arabic">{{ c.num }}</span>
        <span class="badge">&#8709;</span>
      </span>
      {% endif %}
    {% endfor %}
    </div>
  </div>
  {% endfor %}

  <div class="rule double"></div>
  <div class="colophon-bar">
    <div><span style="font-style:italic">Dantis Alagherii</span> &middot; Comedia</div>
    <div class="foliation">Explicit index</div>
    <div>{{ total_conn }} connexionum</div>
  </div>
</div>

</body>
</html>
