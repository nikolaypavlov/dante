<!doctype html>
<html lang="uk">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>Frontispicia · {{ cantica_name }} · Данте у контексті літературних звʼязків</title>
<link rel="stylesheet" href="{{ css_path }}" />
</head>
<body class="theme-{{ cantica }}" data-current-file="frontispicia_{{ cantica }}">

<div class="chrome">
  <div class="chrome-left">
    <button class="nav-btn" onclick="togglePanel()" aria-label="Navigatio">&#9776;</button>
    <a class="project-mark" href="index.html">
      Arbor fontium<span class="sub">&middot; Dantis intertextus &middot;</span>
    </a>
  </div>
  <div class="theme-toggle">
    <a href="index.html"{% if cantica == 'inferno' %} class="active"{% endif %}>Inferno</a>
    <a href="frontispicia_purgatorio.html"{% if cantica == 'purgatorio' %} class="active"{% endif %}>Purgatorio</a>
    <a href="frontispicia_paradiso.html"{% if cantica == 'paradiso' %} class="active"{% endif %}>Paradiso</a>
  </div>
</div>

<div class="side-panel-overlay" id="overlay" onclick="togglePanel()"></div>
<aside class="side-panel" id="sidePanel">
  <div class="side-panel-header">
    <h2>Navigatio</h2>
    <button class="side-panel-close" onclick="togglePanel()" aria-label="Закрити">&#x2715;</button>
  </div>
  <div id="panelContent"></div>
</aside>

<svg width="0" height="0" style="position:absolute">
  <symbol id="fp-corner-ornament" viewBox="0 0 96 96">
    <g fill="none" stroke="currentColor" stroke-linejoin="round" stroke-linecap="round" stroke-width="1">
      <path d="M8 8 L 8 88 M 8 8 L 88 8" stroke-width="1.2"/>
      <path d="M8 8 L 48 8 L 48 48 L 8 48 Z" stroke-width="0.8" opacity="0.5"/>
      <path d="M16 16 Q 30 10, 44 16 Q 56 24, 48 38 Q 40 48, 26 44 Q 14 38, 16 24 Z" stroke-width="1.1"/>
      <path d="M22 22 Q 30 18, 38 24 Q 42 32, 36 38 Q 28 42, 22 36 Z" stroke-width="0.8"/>
      <circle cx="48" cy="48" r="5" fill="currentColor" stroke="none"/>
      <circle cx="48" cy="48" r="3" fill="var(--paper)" stroke="none"/>
      <path d="M8 56 Q 20 62, 20 74 M 8 64 Q 16 72, 12 82" stroke-width="0.7"/>
      <path d="M56 8 Q 62 20, 74 20 M 64 8 Q 72 16, 82 12" stroke-width="0.7"/>
    </g>
  </symbol>
</svg>

<a class="frontispiece" href="{{ first_canto }}.html" title="Відкрити" aria-label="Відкрити">
  <div class="fp-border"></div>
  <svg class="fp-corner tl" viewBox="0 0 96 96"><use href="#fp-corner-ornament"/></svg>
  <svg class="fp-corner tr" viewBox="0 0 96 96"><use href="#fp-corner-ornament"/></svg>
  <svg class="fp-corner bl" viewBox="0 0 96 96"><use href="#fp-corner-ornament"/></svg>
  <svg class="fp-corner br" viewBox="0 0 96 96"><use href="#fp-corner-ornament"/></svg>

  {% if cantica == 'paradiso' %}<div class="fp-stars" id="starField"></div>{% endif %}

  <div class="fp-content">
    <div class="fp-top">
      <div class="fp-kicker">Dantis Alagherii &middot; Comedia</div>
      <div class="fp-fleuron">
        <hr/>
        <svg viewBox="0 0 36 16">
          <g fill="currentColor" stroke="currentColor" stroke-linejoin="round">
            <path d="M18 2 L 22 8 L 18 14 L 14 8 Z"/>
            <circle cx="4" cy="8" r="1.6"/>
            <circle cx="32" cy="8" r="1.6"/>
          </g>
        </svg>
        <hr/>
      </div>
      <h1 class="fp-cantica">{{ cantica_name }}</h1>
      <div class="fp-ordinal">&middot; {{ ordinal }} &middot;</div>
    </div>

    <div class="fp-device" aria-hidden="true">
      <div class="fp-device-halo"></div>
      {% if cantica == 'inferno' %}
      <svg viewBox="0 0 260 260">
        <defs>
          <radialGradient id="inf-abyss" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#0a0503"/>
            <stop offset="70%" stop-color="#1a0804"/>
            <stop offset="100%" stop-color="#2a1a10"/>
          </radialGradient>
        </defs>
        <circle cx="130" cy="130" r="124" fill="url(#inf-abyss)" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="130" cy="130" r="116" fill="none" stroke="var(--gold)" stroke-width="0.6" opacity="0.5"/>
        <circle cx="130" cy="130" r="108" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.6"/>
        <g transform="translate(130 130)">
          <circle r="60" fill="none" stroke="var(--rubric)" stroke-width="0.6" opacity="0.4"/>
          <g fill="none" stroke="var(--rubric)" stroke-width="1" opacity="0.85">
            <circle r="52"/><circle r="44"/><circle r="36"/><circle r="28"/>
            <circle r="20"/><circle r="12"/><circle r="4"/>
          </g>
          <path d="M-2 -2 L 2 -2 L 4 2 L 0 6 L -4 2 Z" fill="var(--rubric)" stroke="var(--gold)" stroke-width="0.4"/>
          <g stroke="var(--rubric)" stroke-width="0.3" opacity="0.4">
            <line x1="0" y1="-52" x2="0" y2="-60"/>
            <line x1="0" y1="52" x2="0" y2="60"/>
            <line x1="-52" y1="0" x2="-60" y2="0"/>
            <line x1="52" y1="0" x2="60" y2="0"/>
            <line x1="-37" y1="-37" x2="-42" y2="-42"/>
            <line x1="37" y1="-37" x2="42" y2="-42"/>
            <line x1="-37" y1="37" x2="-42" y2="42"/>
            <line x1="37" y1="37" x2="42" y2="42"/>
          </g>
        </g>
        <g stroke="var(--gold)" stroke-width="0.7" fill="none" opacity="0.5">
          <circle cx="130" cy="130" r="128" stroke-dasharray="2 4"/>
        </g>
      </svg>
      {% elif cantica == 'purgatorio' %}
      <svg viewBox="0 0 260 260">
        <defs>
          <linearGradient id="pur-dawn" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#a8c4e8"/>
            <stop offset="50%" stop-color="#e8c88a"/>
            <stop offset="100%" stop-color="#c89a3a"/>
          </linearGradient>
          <linearGradient id="pur-sea" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#4a6ba8"/>
            <stop offset="100%" stop-color="#2a3a68"/>
          </linearGradient>
          <clipPath id="pur-disc">
            <circle cx="130" cy="130" r="124"/>
          </clipPath>
        </defs>
        <circle cx="130" cy="130" r="124" fill="url(#pur-dawn)" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="130" cy="130" r="116" fill="none" stroke="var(--gold)" stroke-width="0.6" opacity="0.6"/>
        <circle cx="130" cy="130" r="108" fill="none" stroke="currentColor" stroke-width="0.6" opacity="0.4"/>
        <g clip-path="url(#pur-disc)">
          <path d="M10 180 Q 60 176 110 180 Q 160 184 210 180 Q 250 178 250 180 L 250 254 L 10 254 Z" fill="url(#pur-sea)" opacity="0.9"/>
          <g stroke="var(--paper)" stroke-width="0.6" fill="none" opacity="0.5">
            <path d="M20 190 Q 40 186 60 190 T 100 190 T 140 190 T 180 190 T 220 190 T 244 190"/>
            <path d="M24 200 Q 44 196 64 200 T 104 200 T 144 200 T 184 200 T 224 200 T 244 200"/>
            <path d="M30 212 Q 50 208 70 212 T 110 212 T 150 212 T 190 212 T 230 212"/>
          </g>
        </g>
        <g>
          <ellipse cx="130" cy="180" rx="66" ry="8" fill="var(--ink)" opacity="0.4"/>
          <path d="M80 180 L 110 130 L 130 120 L 150 130 L 180 180 Z" fill="var(--paper)" stroke="currentColor" stroke-width="1.2"/>
          <g stroke="currentColor" stroke-width="0.7" fill="none" opacity="0.85">
            <path d="M84 172 L 176 172"/>
            <path d="M92 162 L 168 162"/>
            <path d="M99 152 L 161 152"/>
            <path d="M105 144 L 155 144"/>
            <path d="M111 136 L 149 136"/>
            <path d="M116 130 L 144 130"/>
            <path d="M120 126 L 140 126"/>
          </g>
        </g>
        <g fill="var(--gold)" stroke="var(--border-ink)" stroke-width="0.4">
          <path d="M106 72 L 108 76 L 112 76 L 109 79 L 110 83 L 106 81 L 102 83 L 103 79 L 100 76 L 104 76 Z"/>
          <path d="M130 60 L 132 64 L 136 64 L 133 67 L 134 71 L 130 69 L 126 71 L 127 67 L 124 64 L 128 64 Z"/>
          <path d="M154 72 L 156 76 L 160 76 L 157 79 L 158 83 L 154 81 L 150 83 L 151 79 L 148 76 L 152 76 Z"/>
          <path d="M130 92 L 132 96 L 136 96 L 133 99 L 134 103 L 130 101 L 126 103 L 127 99 L 124 96 L 128 96 Z"/>
        </g>
        <g stroke="var(--rubric)" stroke-width="0.6" fill="none" opacity="0.4">
          <path d="M130 40 L 130 14"/>
          <path d="M110 46 L 100 24"/>
          <path d="M150 46 L 160 24"/>
          <path d="M90 60 L 72 42"/>
          <path d="M170 60 L 188 42"/>
        </g>
      </svg>
      {% else %}
      <svg viewBox="0 0 260 260">
        <defs>
          <radialGradient id="par-empyrean" cx="50%" cy="50%" r="50%">
            <stop offset="0%" stop-color="#fff8d8"/>
            <stop offset="40%" stop-color="#e8c547"/>
            <stop offset="100%" stop-color="#4a3a10"/>
          </radialGradient>
        </defs>
        <circle cx="130" cy="130" r="124" fill="#0a1530" stroke="currentColor" stroke-width="1.5"/>
        <g fill="none" stroke="currentColor" stroke-width="0.7" opacity="0.7">
          <circle cx="130" cy="130" r="116"/>
          <circle cx="130" cy="130" r="104"/>
          <circle cx="130" cy="130" r="92"/>
          <circle cx="130" cy="130" r="80"/>
          <circle cx="130" cy="130" r="68"/>
          <circle cx="130" cy="130" r="56"/>
          <circle cx="130" cy="130" r="44"/>
          <circle cx="130" cy="130" r="32"/>
          <circle cx="130" cy="130" r="20"/>
        </g>
        <g stroke="currentColor" stroke-width="0.3" opacity="0.3">
          <line x1="130" y1="10" x2="130" y2="250"/>
          <line x1="10" y1="130" x2="250" y2="130"/>
          <line x1="45" y1="45" x2="215" y2="215"/>
          <line x1="215" y1="45" x2="45" y2="215"/>
        </g>
        <circle cx="130" cy="130" r="14" fill="url(#par-empyrean)"/>
        <g fill="currentColor" opacity="0.95">
          <g transform="translate(130 130)">
            <ellipse cx="0" cy="-9" rx="2" ry="5" opacity="0.9"/>
            <ellipse cx="6.4" cy="-6.4" rx="2" ry="5" transform="rotate(45 6.4 -6.4)" opacity="0.85"/>
            <ellipse cx="9" cy="0" rx="2" ry="5" transform="rotate(90 9 0)" opacity="0.9"/>
            <ellipse cx="6.4" cy="6.4" rx="2" ry="5" transform="rotate(135 6.4 6.4)" opacity="0.85"/>
            <ellipse cx="0" cy="9" rx="2" ry="5" opacity="0.9"/>
            <ellipse cx="-6.4" cy="6.4" rx="2" ry="5" transform="rotate(45 -6.4 6.4)" opacity="0.85"/>
            <ellipse cx="-9" cy="0" rx="2" ry="5" transform="rotate(90 -9 0)" opacity="0.9"/>
            <ellipse cx="-6.4" cy="-6.4" rx="2" ry="5" transform="rotate(135 -6.4 -6.4)" opacity="0.85"/>
            <circle r="2.6" fill="#fff8d8"/>
          </g>
        </g>
        <g stroke="currentColor" stroke-width="0.35" opacity="0.5">
          <line x1="130" y1="130" x2="130" y2="14"/>
          <line x1="130" y1="130" x2="246" y2="130"/>
          <line x1="130" y1="130" x2="130" y2="246"/>
          <line x1="130" y1="130" x2="14" y2="130"/>
          <line x1="130" y1="130" x2="210" y2="50"/>
          <line x1="130" y1="130" x2="50" y2="50"/>
          <line x1="130" y1="130" x2="210" y2="210"/>
          <line x1="130" y1="130" x2="50" y2="210"/>
        </g>
        <g fill="var(--gold)" stroke="none">
          <circle cx="78" cy="90" r="1.4"/>
          <circle cx="180" cy="88" r="1.2"/>
          <circle cx="200" cy="160" r="1.3"/>
          <circle cx="60" cy="160" r="1.4"/>
          <circle cx="90" cy="180" r="1.2"/>
          <circle cx="170" cy="180" r="1.3"/>
          <circle cx="150" cy="70" r="1"/>
          <circle cx="100" cy="70" r="1"/>
          <circle cx="210" cy="130" r="1.3"/>
          <circle cx="50" cy="130" r="1.3"/>
        </g>
      </svg>
      {% endif %}
    </div>

    <div class="fp-bottom">
      <div class="fp-fleuron"><hr/><svg viewBox="0 0 36 16"><g fill="currentColor"><path d="M18 2 L 22 8 L 18 14 L 14 8 Z"/><circle cx="4" cy="8" r="1.2"/><circle cx="32" cy="8" r="1.2"/></g></svg><hr/></div>
      <blockquote class="fp-incipit">{{ incipit | safe }}</blockquote>
    </div>
    <div class="fp-setting">{{ setting | safe }}</div>
  </div>

  {% if cantica == 'inferno' %}
  <svg class="fp-flames" viewBox="0 0 720 22" preserveAspectRatio="none">
    <g fill="currentColor" opacity="0.8">
      <path d="M0 22 Q 10 10 20 22 Q 30 6 40 22 Q 50 12 60 22 Q 70 4 80 22 Q 90 12 100 22 Q 110 8 120 22 Q 130 14 140 22 Q 150 2 160 22 Q 170 12 180 22 Q 190 10 200 22 Q 210 4 220 22 Q 230 14 240 22 Q 250 8 260 22 Q 270 12 280 22 Q 290 6 300 22 Q 310 14 320 22 Q 330 10 340 22 Q 350 2 360 22 Q 370 12 380 22 Q 390 8 400 22 Q 410 14 420 22 Q 430 4 440 22 Q 450 12 460 22 Q 470 10 480 22 Q 490 6 500 22 Q 510 14 520 22 Q 530 8 540 22 Q 550 12 560 22 Q 570 4 580 22 Q 590 14 600 22 Q 610 10 620 22 Q 630 2 640 22 Q 650 12 660 22 Q 670 8 680 22 Q 690 14 700 22 Q 710 10 720 22 Z"/>
    </g>
  </svg>
  {% elif cantica == 'purgatorio' %}
  <svg class="fp-mountain" viewBox="0 0 720 80" preserveAspectRatio="none">
    <path d="M0 80 L 0 60 Q 40 40, 90 50 Q 140 60, 180 30 Q 220 5, 260 28 Q 290 45, 330 20 Q 370 0, 410 25 Q 450 50, 490 30 Q 530 10, 580 40 Q 620 60, 660 42 Q 700 30, 720 55 L 720 80 Z" fill="currentColor"/>
  </svg>
  {% endif %}
</a>

<script src="{{ js_path }}"></script>
{% if cantica == 'paradiso' %}
<script>
(function(){
  var stars = document.getElementById('starField');
  if (!stars) return;
  for (var i = 0; i < 60; i++) {
    var s = document.createElement('div');
    s.className = 'star-pt';
    s.style.left = (Math.random() * 100) + '%';
    s.style.top = (Math.random() * 100) + '%';
    var size = 1 + Math.random() * 1.8;
    s.style.width = size + 'px';
    s.style.height = size + 'px';
    s.style.opacity = (0.35 + Math.random() * 0.5).toFixed(2);
    stars.appendChild(s);
  }
})();
</script>
{% endif %}
</body>
</html>
